{
  "name": "zeta-beta-mu-portal",
  "version": "1.0.0",
  "private": true,
  "description": "Zeta Beta Mu Fraternity Portal - static shell with Tailwind build step",
  "scripts": {
    "build:tw": "tailwindcss -i src/tailwind-input.css -o css/tailwind.css --minify",
    "build:css": "csso css/styles.css -o css/styles.min.css",
    "build": "npm run build:tw && npm run build:css",
    "watch:tw": "tailwindcss -i src/tailwind-input.css -o css/tailwind.css --watch"
  },
  "devDependencies": {
    "csso-cli": "^4.0.2",
    "tailwindcss": "^3.4.17"
  }
}
